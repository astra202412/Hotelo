@{
    ViewData["Title"] = "Finances & Facturation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">
        <i class="bi bi-receipt text-success me-2"></i>Finances & Facturation
    </h5>
    <div>
        <button class="btn btn-dark btn-sm me-2" data-bs-toggle="modal" data-bs-target="#newInvoiceModal">
            <i class="bi bi-plus-lg"></i> Nouvelle Facture
        </button>
        <a href="/api/v1/export/finances/excel" class="btn btn-success btn-sm">
            <i class="bi bi-file-earmark-excel"></i> Export Excel
        </a>
    </div>
</div>

<!-- KPIs -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card shadow-sm text-center py-3">
            <div class="fs-3 fw-bold text-success" id="kpiToday">-</div>
            <small class="text-muted">Revenu Aujourd hui</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card shadow-sm text-center py-3">
            <div class="fs-3 fw-bold text-primary" id="kpiMonth">-</div>
            <small class="text-muted">Revenu Ce Mois</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card shadow-sm text-center py-3">
            <div class="fs-3 fw-bold text-warning" id="kpiUnpaid">-</div>
            <small class="text-muted">Factures Impayees</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card shadow-sm text-center py-3">
            <div class="fs-3 fw-bold text-danger" id="kpiPending">-</div>
            <small class="text-muted">Montant En Attente</small>
        </div>
    </div>
</div>

<!-- Liste Factures -->
<div class="card shadow-sm">
    <div class="card-header bg-white fw-semibold py-3">
        <i class="bi bi-file-earmark-text me-2"></i>Toutes les Factures
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Numero</th>
                        <th>Client</th>
                        <th>Chambre</th>
                        <th>Nuits</th>
                        <th>Total HT</th>
                        <th>TVA 19%</th>
                        <th>Total TTC</th>
                        <th>Statut</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="invoicesBody">
                    <tr><td colspan="10" class="text-center py-4">
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    </td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Paiement -->
<div class="modal fade" id="paymentModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h6 class="modal-title">Enregistrer Paiement</h6>
                <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="payInvoiceId" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Facture</label>
                    <div id="payInvoiceInfo" class="alert alert-info py-2 small"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Montant (DZD)</label>
                    <input type="number" id="payAmount" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Methode</label>
                    <select id="payMethod" class="form-select">
                        <option value="Especes">Especes</option>
                        <option value="CarteBancaire">Carte Bancaire</option>
                        <option value="Virement">Virement</option>
                        <option value="Cheque">Cheque</option>
                        <option value="Prepaiement">Prepaiement</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Reference</label>
                    <input type="text" id="payRef" class="form-control" placeholder="N de cheque, virement..." />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-success" onclick="registerPayment()">
                    <i class="bi bi-check-lg"></i> Valider
                </button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Nouvelle Facture -->
<div class="modal fade" id="newInvoiceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h6 class="modal-title">Generer une Facture</h6>
                <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Reservation</label>
                    <select id="invReservation" class="form-select" onchange="loadReservationInfo()">
                        <option value="">-- Selectionner une reservation --</option>
                    </select>
                </div>
                <div id="reservationInfo" class="alert alert-info d-none small"></div>
                <div class="mb-3">
                    <label class="form-label">Remise (DZD)</label>
                    <input type="number" id="invDiscount" class="form-control" value="0" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Notes</label>
                    <textarea id="invNotes" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-dark" onclick="generateInvoice()">
                    <i class="bi bi-receipt"></i> Generer
                </button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var allReservations = [];
var allInvoices = [];

async function loadData() {
    // Dashboard
    const dash = await fetch('/api/v1/invoices/dashboard');
    const dashData = (await dash.json()).data;
    document.getElementById('kpiToday').textContent   = dashData.totalRevenueToday.toLocaleString() + ' DZD';
    document.getElementById('kpiMonth').textContent   = dashData.totalRevenueMonth.toLocaleString() + ' DZD';
    document.getElementById('kpiUnpaid').textContent  = dashData.unpaidInvoices;
    document.getElementById('kpiPending').textContent = dashData.pendingAmount.toLocaleString() + ' DZD';

    // Factures
    const inv = await fetch('/api/v1/invoices');
    allInvoices = (await inv.json()).data || [];
    renderInvoices();

    // Reservations pour le select
    const res = await fetch('/api/v1/reservations');
    allReservations = (await res.json()).data || [];
    const sel = document.getElementById('invReservation');
    sel.innerHTML = '<option value="">-- Selectionner --</option>' +
        allReservations
            .filter(r => r.status === 3 || r.status === 2) // CheckedIn ou Confirmee
            .map(r => `<option value="${r.id}">${r.confirmationCode} — ${r.guestName} — Ch.${r.roomNumber}</option>`)
            .join('');
}

function renderInvoices() {
    const tbody = document.getElementById('invoicesBody');
    if (!allInvoices.length) {
        tbody.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-4">Aucune facture</td></tr>';
        return;
    }
    tbody.innerHTML = allInvoices.map(i => `
        <tr>
            <td><small class="font-monospace fw-semibold">${i.invoiceNumber}</small></td>
            <td>${i.guestName}</td>
            <td><strong>${i.roomNumber}</strong></td>
            <td class="text-center">${i.nights}</td>
            <td>${i.totalHT.toLocaleString()} DZD</td>
            <td>${i.tvaAmount.toLocaleString()} DZD</td>
            <td><strong>${i.totalTTC.toLocaleString()} DZD</strong></td>
            <td>
                <span class="badge" style="background:${i.isPaid ? '#4CAF50' : '#F44336'}">
                    ${i.isPaid ? 'Payee' : 'Impayee'}
                </span>
            </td>
            <td><small>${new Date(i.createdAt).toLocaleDateString('fr-FR')}</small></td>
            <td>
                <a href="/api/v1/export/invoice/${i.id}/pdf" target="_blank"
                   class="btn btn-xs btn-sm btn-outline-primary me-1" title="PDF">
                    <i class="bi bi-file-pdf"></i>
                </a>
                ${!i.isPaid ? `
                <button class="btn btn-xs btn-sm btn-success" title="Paiement"
                    onclick="openPayment(${i.id}, ${i.totalTTC}, '${i.invoiceNumber}')">
                    <i class="bi bi-cash"></i>
                </button>` : ''}
            </td>
        </tr>`).join('');
}

function loadReservationInfo() {
    const id = document.getElementById('invReservation').value;
    const infoDiv = document.getElementById('reservationInfo');
    if (!id) { infoDiv.classList.add('d-none'); return; }
    const res = allReservations.find(r => r.id == id);
    if (res) {
        infoDiv.innerHTML = `
            <strong>${res.guestName}</strong> — Chambre ${res.roomNumber} (${res.roomType})<br>
            Arrivee : ${new Date(res.checkIn).toLocaleDateString('fr-FR')} |
            Depart  : ${new Date(res.checkOut).toLocaleDateString('fr-FR')} |
            Nuits   : ${res.nights}<br>
            <strong>Montant estimé : ${res.totalAmount.toLocaleString()} DZD</strong>`;
        infoDiv.classList.remove('d-none');
    }
}

function openPayment(invoiceId, totalTTC, invoiceNumber) {
    document.getElementById('payInvoiceId').value = invoiceId;
    document.getElementById('payAmount').value    = totalTTC;
    document.getElementById('payInvoiceInfo').textContent = invoiceNumber + ' — ' + totalTTC.toLocaleString() + ' DZD';
    new bootstrap.Modal(document.getElementById('paymentModal')).show();
}

async function registerPayment() {
    const dto = {
        invoiceId : parseInt(document.getElementById('payInvoiceId').value),
        amount    : parseFloat(document.getElementById('payAmount').value),
        method    : document.getElementById('payMethod').value,
        reference : document.getElementById('payRef').value,
        notes     : null
    };
    const r = await fetch('/api/v1/invoices/payment', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(dto)
    });
    const data = await r.json();
    if (data.success) {
        bootstrap.Modal.getInstance(document.getElementById('paymentModal')).hide();
        loadData();
    }
}

async function generateInvoice() {
    const resId = document.getElementById('invReservation').value;
    if (!resId) { alert('Selectionnez une reservation'); return; }
    const dto = {
        reservationId : parseInt(resId),
        discount      : parseFloat(document.getElementById('invDiscount').value) || 0,
        notes         : document.getElementById('invNotes').value
    };
    const r = await fetch('/api/v1/invoices/generate', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(dto)
    });
    const data = await r.json();
    if (data.success) {
        bootstrap.Modal.getInstance(document.getElementById('newInvoiceModal')).hide();
        loadData();
    }
}

loadData();
</script>
}
