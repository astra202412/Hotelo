@{
    ViewData["Title"] = "Administration — Utilisateurs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0"><i class="bi bi-shield-lock text-danger me-2"></i>Gestion des Utilisateurs</h5>
    <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#newUserModal">
        <i class="bi bi-plus-lg"></i> Nouvel Utilisateur
    </button>
</div>

<!-- KPIs -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card shadow-sm text-center py-3">
            <div class="fs-3 fw-bold text-dark" id="kpiTotal">-</div>
            <small class="text-muted">Total Utilisateurs</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card shadow-sm text-center py-3">
            <div class="fs-3 fw-bold text-success" id="kpiActive">-</div>
            <small class="text-muted">Actifs</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card shadow-sm text-center py-3">
            <div class="fs-3 fw-bold text-primary" id="kpiRoles">-</div>
            <small class="text-muted">Roles Disponibles</small>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card shadow-sm text-center py-3">
            <div class="fs-3 fw-bold text-warning">HOTELO</div>
            <small class="text-muted">v1.0.0</small>
        </div>
    </div>
</div>

<!-- Tableau Utilisateurs -->
<div class="card shadow-sm">
    <div class="card-header bg-white fw-semibold py-3">
        <i class="bi bi-people me-2"></i>Utilisateurs du Systeme
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Nom</th><th>Email</th><th>Roles</th><th>Statut</th><th>Actions</th></tr>
                </thead>
                <tbody id="usersBody">
                    <tr><td colspan="5" class="text-center py-4">
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    </td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Nouvel Utilisateur -->
<div class="modal fade" id="newUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h6 class="modal-title">Nouvel Utilisateur</h6>
                <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Nom Complet</label>
                        <input type="text" id="uName" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Email</label>
                        <input type="email" id="uEmail" class="form-control" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Mot de passe</label>
                        <input type="password" id="uPassword" class="form-control" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Role</label>
                        <select id="uRole" class="form-select">
                            <option value="Admin">Admin</option>
                            <option value="Directeur">Directeur</option>
                            <option value="Receptionniste">Receptionniste</option>
                            <option value="Comptable">Comptable</option>
                            <option value="Gouvernante">Gouvernante</option>
                            <option value="Technicien">Technicien</option>
                            <option value="RH">RH</option>
                            <option value="Commercial">Commercial</option>
                            <option value="BellDesk">BellDesk</option>
                        </select>
                    </div>
                </div>
                <div id="createError" class="alert alert-danger mt-3 d-none"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-dark" onclick="createUser()">Creer</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Changer Mot de Passe -->
<div class="modal fade" id="pwdModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h6 class="modal-title">Changer Mot de Passe</h6>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="pwdUserId" />
                <label class="form-label">Nouveau Mot de Passe</label>
                <input type="password" id="newPwd" class="form-control" />
            </div>
            <div class="modal-footer">
                <button class="btn btn-warning" onclick="changePwd()">Confirmer</button>
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Annuler</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var availableRoles = [];

async function loadData() {
    const dash = await fetch('/api/v1/users/dashboard');
    const d = (await dash.json()).data;
    document.getElementById('kpiTotal').textContent  = d.totalUsers;
    document.getElementById('kpiActive').textContent = d.activeUsers;
    document.getElementById('kpiRoles').textContent  = d.totalRoles;
    availableRoles = d.availableRoles;

    const tbody = document.getElementById('usersBody');
    tbody.innerHTML = d.users.map(u => `
        <tr>
            <td><strong>${u.fullName}</strong></td>
            <td><small>${u.email}</small></td>
            <td>${u.roles.map(r => `<span class="badge bg-dark me-1">${r}</span>`).join('')}</td>
            <td>
                <span class="badge" style="background:${u.isActive ? '#4CAF50' : '#F44336'}">
                    ${u.isActive ? 'Actif' : 'Inactif'}
                </span>
            </td>
            <td>
                <button class="btn btn-xs btn-sm btn-outline-warning me-1"
                    onclick="openPwd('${u.id}')">
                    <i class="bi bi-key"></i>
                </button>
                ${u.isActive ? `<button class="btn btn-xs btn-sm btn-outline-danger"
                    onclick="deactivate('${u.id}')">
                    <i class="bi bi-person-x"></i>
                </button>` : ''}
            </td>
        </tr>`).join('');
}

async function createUser() {
    const dto = {
        fullName: document.getElementById('uName').value,
        email:    document.getElementById('uEmail').value,
        password: document.getElementById('uPassword').value,
        role:     document.getElementById('uRole').value
    };
    const r = await fetch('/api/v1/users', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(dto)
    });
    const data = await r.json();
    if (!data.success) {
        document.getElementById('createError').textContent = data.errors[0];
        document.getElementById('createError').classList.remove('d-none');
        return;
    }
    bootstrap.Modal.getInstance(document.getElementById('newUserModal')).hide();
    loadData();
}

function openPwd(id) {
    document.getElementById('pwdUserId').value = id;
    new bootstrap.Modal(document.getElementById('pwdModal')).show();
}

async function changePwd() {
    const dto = {
        userId: document.getElementById('pwdUserId').value,
        newPassword: document.getElementById('newPwd').value
    };
    await fetch('/api/v1/users/change-password', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(dto)
    });
    bootstrap.Modal.getInstance(document.getElementById('pwdModal')).hide();
}

async function deactivate(id) {
    if (!confirm('Desactiver cet utilisateur ?')) return;
    await fetch('/api/v1/users/' + id, { method: 'DELETE' });
    loadData();
}

loadData();
</script>
}
