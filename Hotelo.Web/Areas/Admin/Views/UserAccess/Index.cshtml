@model Hotelo.Core.DTOs.Admin.AccessMatrixDto
@{
    ViewData["Title"] = "Matrice des Droits d'Acces";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">
            <i class="bi bi-shield-lock me-2 text-primary"></i>Matrice des Droits d'Acces
        </h4>
        <div class="d-flex gap-2">
            <button class="btn btn-success btn-sm" onclick="checkAll()">
                <i class="bi bi-check2-all me-1"></i>Tout cocher
            </button>
            <button class="btn btn-secondary btn-sm" onclick="uncheckAll()">
                <i class="bi bi-x-square me-1"></i>Tout decocher
            </button>
            <button class="btn btn-outline-success btn-sm" onclick="checkColumn('CanView')">
                <i class="bi bi-eye me-1"></i>Tout Voir
            </button>
            <button class="btn btn-outline-danger btn-sm" onclick="uncheckColumn('CanView')">
                <i class="bi bi-eye-slash me-1"></i>Aucun Voir
            </button>
            <button class="btn btn-primary btn-sm" onclick="saveAll()">
                <i class="bi bi-floppy me-1"></i>Enregistrer tout
            </button>
        </div>
    </div>

    <!-- Barre de filtres rapides par colonne -->
    <div class="card mb-3 border-0 shadow-sm">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold me-2">Selection rapide :</span>
                @foreach (var col in new[] { "CanView", "CanCreate", "CanEdit", "CanDelete", "CanExport" })
                {
                    var label = col switch {
                        "CanView"   => "Voir",
                        "CanCreate" => "Creer",
                        "CanEdit"   => "Modifier",
                        "CanDelete" => "Supprimer",
                        "CanExport" => "Exporter",
                        _           => col
                    };
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-primary" onclick="checkColumn('@col')">
                            <i class="bi bi-check2"></i> @label
                        </button>
                        <button class="btn btn-outline-secondary" onclick="uncheckColumn('@col')">
                            <i class="bi bi-x"></i>
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Tableau matrice -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-sm mb-0" id="matrixTable">
                    <thead class="table-dark sticky-top">
                        <tr>
                            <th style="min-width:160px">Fonction / Poste</th>
                            <th style="min-width:140px">Departement</th>
                            <th style="min-width:160px">Module</th>
                            <th class="text-center" style="width:80px">
                                <div>Voir</div>
                                <div class="form-check form-check-inline m-0">
                                    <input type="checkbox" class="form-check-input col-toggle" data-col="CanView"
                                           onchange="toggleColumn('CanView', this.checked)" title="Tout cocher/decocher">
                                </div>
                            </th>
                            <th class="text-center" style="width:80px">
                                <div>Creer</div>
                                <input type="checkbox" class="form-check-input col-toggle" data-col="CanCreate"
                                       onchange="toggleColumn('CanCreate', this.checked)">
                            </th>
                            <th class="text-center" style="width:80px">
                                <div>Modifier</div>
                                <input type="checkbox" class="form-check-input col-toggle" data-col="CanEdit"
                                       onchange="toggleColumn('CanEdit', this.checked)">
                            </th>
                            <th class="text-center" style="width:80px">
                                <div>Supprimer</div>
                                <input type="checkbox" class="form-check-input col-toggle" data-col="CanDelete"
                                       onchange="toggleColumn('CanDelete', this.checked)">
                            </th>
                            <th class="text-center" style="width:80px">
                                <div>Exporter</div>
                                <input type="checkbox" class="form-check-input col-toggle" data-col="CanExport"
                                       onchange="toggleColumn('CanExport', this.checked)">
                            </th>
                            <th class="text-center" style="width:70px">
                                <div>Ligne</div>
                                <small class="text-muted">tout</small>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var func in Model.Functions)
                        {
                            var funcAccesses = Model.AccessRules.Where(a => a.JobFunctionId == func.Id).ToList();
                            bool firstRow = true;
                            int rowCount  = Model.Modules.Count;

                            @foreach (var module in Model.Modules)
                            {
                                var access = funcAccesses.FirstOrDefault(a => a.AppModuleId == module.Id);
                                <tr data-function-id="@func.Id" data-module-id="@module.Id">
                                    @if (firstRow)
                                    {
                                        <td rowspan="@rowCount" class="align-middle fw-bold bg-light">
                                            <i class="bi bi-person-badge me-1 text-primary"></i>@func.Name
                                        </td>
                                        <td rowspan="@rowCount" class="align-middle text-muted small bg-light">
                                            <i class="bi bi-building me-1"></i>@func.DepartmentName
                                        </td>
                                        firstRow = false;
                                    }
                                    <td class="small">
                                        <i class="bi bi-grid me-1 text-secondary"></i>@module.Name
                                    </td>
                                    @foreach (var col in new[] { "CanView", "CanCreate", "CanEdit", "CanDelete", "CanExport" })
                                    {
                                        bool val = col switch {
                                            "CanView"   => access?.CanView   ?? false,
                                            "CanCreate" => access?.CanCreate ?? false,
                                            "CanEdit"   => access?.CanEdit   ?? false,
                                            "CanDelete" => access?.CanDelete ?? false,
                                            "CanExport" => access?.CanExport ?? false,
                                            _           => false
                                        };
                                        <td class="text-center">
                                            <input type="checkbox"
                                                   class="form-check-input access-cb cb-@col"
                                                   data-function-id="@func.Id"
                                                   data-module-id="@module.Id"
                                                   data-col="@col"
                                                   @(val ? "checked" : "")
                                                   onchange="markDirty(this)" />
                                        </td>
                                    }
                                    <td class="text-center">
                                        <button class="btn btn-link btn-sm p-0 text-primary"
                                                onclick="toggleRow(this)" title="Tout cocher/decocher cette ligne">
                                            <i class="bi bi-arrow-left-right"></i>
                                        </button>
                                    </td>
                                </tr>
                                firstRow = false;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Barre de statut -->
    <div class="mt-2 d-flex justify-content-between align-items-center">
        <small class="text-muted" id="statusMsg"></small>
        <button class="btn btn-primary" onclick="saveAll()">
            <i class="bi bi-floppy me-1"></i>Enregistrer les modifications
        </button>
    </div>
</div>

@section Scripts {
<script>
    // Suivi des cases modifiees
    const dirty = new Set();

    function markDirty(cb) {
        dirty.add(cb);
        document.getElementById('statusMsg').textContent =
            dirty.size + ' modification(s) non enregistree(s)';
    }

    // Tout cocher
    function checkAll() {
        document.querySelectorAll('.access-cb').forEach(cb => {
            if (!cb.checked) { cb.checked = true; markDirty(cb); }
        });
        syncColToggles();
    }

    // Tout decocher
    function uncheckAll() {
        document.querySelectorAll('.access-cb').forEach(cb => {
            if (cb.checked) { cb.checked = false; markDirty(cb); }
        });
        syncColToggles();
    }

    // Cocher une colonne entiere
    function checkColumn(col) {
        document.querySelectorAll('.cb-' + col).forEach(cb => {
            if (!cb.checked) { cb.checked = true; markDirty(cb); }
        });
        const toggle = document.querySelector('.col-toggle[data-col="' + col + '"]');
        if (toggle) toggle.checked = true;
    }

    // Decocher une colonne entiere
    function uncheckColumn(col) {
        document.querySelectorAll('.cb-' + col).forEach(cb => {
            if (cb.checked) { cb.checked = false; markDirty(cb); }
        });
        const toggle = document.querySelector('.col-toggle[data-col="' + col + '"]');
        if (toggle) toggle.checked = false;
    }

    // Toggle colonne via checkbox header
    function toggleColumn(col, checked) {
        document.querySelectorAll('.cb-' + col).forEach(cb => {
            if (cb.checked !== checked) { cb.checked = checked; markDirty(cb); }
        });
    }

    // Toggle ligne entiere
    function toggleRow(btn) {
        const row  = btn.closest('tr');
        const cbs  = row.querySelectorAll('.access-cb');
        const allChecked = [...cbs].every(cb => cb.checked);
        cbs.forEach(cb => { cb.checked = !allChecked; markDirty(cb); });
    }

    // Synchroniser les checkboxes header avec etat colonne
    function syncColToggles() {
        ['CanView','CanCreate','CanEdit','CanDelete','CanExport'].forEach(col => {
            const cbs    = document.querySelectorAll('.cb-' + col);
            const toggle = document.querySelector('.col-toggle[data-col="' + col + '"]');
            if (toggle) toggle.checked = [...cbs].every(cb => cb.checked);
        });
    }

    // Enregistrer toutes les modifications
    async function saveAll() {
        if (dirty.size === 0) {
            showToast('Aucune modification a enregistrer', 'info');
            return;
        }

        // Grouper par fonction + module (une seule requete par ligne)
        const rows = {};
        dirty.forEach(cb => {
            const key = cb.dataset.functionId + '_' + cb.dataset.moduleId;
            if (!rows[key]) {
                rows[key] = {
                    jobFunctionId : parseInt(cb.dataset.functionId),
                    appModuleId   : parseInt(cb.dataset.moduleId),
                    canView:false, canCreate:false, canEdit:false, canDelete:false, canExport:false
                };
            }
        });

        // Relire toutes les cases de chaque ligne concernee
        Object.keys(rows).forEach(key => {
            const [fId, mId] = key.split('_');
            const rowCbs = document.querySelectorAll(
                '.access-cb[data-function-id="' + fId + '"][data-module-id="' + mId + '"]');
            rowCbs.forEach(cb => {
                const col = cb.dataset.col;
                if (col === 'CanView')   rows[key].canView   = cb.checked;
                if (col === 'CanCreate') rows[key].canCreate = cb.checked;
                if (col === 'CanEdit')   rows[key].canEdit   = cb.checked;
                if (col === 'CanDelete') rows[key].canDelete = cb.checked;
                if (col === 'CanExport') rows[key].canExport = cb.checked;
            });
        });

        const promises = Object.values(rows).map(dto =>
            fetch('/Admin/UserAccess/Update', {
                method  : 'POST',
                headers : { 'Content-Type': 'application/json' },
                body    : JSON.stringify(dto)
            })
        );

        try {
            await Promise.all(promises);
            dirty.clear();
            document.getElementById('statusMsg').textContent = '';
            showToast('Droits enregistres avec succes', 'success');
        } catch (err) {
            showToast('Erreur lors de l enregistrement', 'danger');
        }
    }

    function showToast(msg, type) {
        const toast = document.createElement('div');
        toast.className = 'toast align-items-center text-bg-' + type + ' border-0 show position-fixed bottom-0 end-0 m-3';
        toast.style.zIndex = 9999;
        toast.innerHTML = '<div class="d-flex"><div class="toast-body">' + msg +
            '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" onclick="this.closest(\'.toast\').remove()"></button></div>';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }
</script>
}