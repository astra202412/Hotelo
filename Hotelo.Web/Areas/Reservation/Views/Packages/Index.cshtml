@{
    ViewData["Title"] = "Packages & Tarifs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">
        <i class="bi bi-gift text-primary me-2"></i>Packages & Tarifs
    </h5>
    <button class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#newPackageModal">
        <i class="bi bi-plus-lg"></i> Nouveau Package
    </button>
</div>

<!-- Packages Cards -->
<div class="row g-3" id="packagesGrid">
    <div class="col-12 text-center py-4">
        <div class="spinner-border text-primary"></div>
    </div>
</div>

<!-- Modal Nouveau Package -->
<div class="modal fade" id="newPackageModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h6 class="modal-title">Nouveau Package</h6>
                <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-8">
                        <label class="form-label">Nom du Package</label>
                        <input type="text" id="pkgName" class="form-control" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">Prix Additionnel / nuit</label>
                        <input type="number" id="pkgPrice" class="form-control" value="0" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <textarea id="pkgDesc" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Nuits minimum</label>
                        <input type="number" id="pkgMinNights" class="form-control" placeholder="Optionnel" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Inclusions</label>
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="pkgBreakfast" />
                                    <label class="form-check-label" for="pkgBreakfast">
                                        <i class="bi bi-cup-hot me-1"></i>Petit-dejeuner
                                    </label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="pkgParking" />
                                    <label class="form-check-label" for="pkgParking">
                                        <i class="bi bi-p-square me-1"></i>Parking
                                    </label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="pkgSpa" />
                                    <label class="form-check-label" for="pkgSpa">
                                        <i class="bi bi-stars me-1"></i>Spa
                                    </label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="pkgTransfer" />
                                    <label class="form-check-label" for="pkgTransfer">
                                        <i class="bi bi-airplane me-1"></i>Transfert Aeroport
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-dark" onclick="createPackage()">Creer</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
async function loadPackages() {
    const r    = await fetch('/api/v1/packages');
    const pkgs = (await r.json()).data || [];
    const grid = document.getElementById('packagesGrid');

    if (!pkgs.length) {
        grid.innerHTML = '<div class="col-12 text-center text-muted py-4">Aucun package</div>';
        return;
    }

    grid.innerHTML = pkgs.map(p => `
        <div class="col-md-4">
            <div class="card shadow-sm h-100 ${!p.isActive ? 'opacity-50' : ''}">
                <div class="card-header d-flex justify-content-between align-items-center py-2"
                     style="background:${p.isActive ? '#1E3A5F' : '#9E9E9E'}">
                    <span class="text-white fw-bold">${p.name}</span>
                    <span class="badge bg-warning text-dark">
                        +${p.additionalPrice.toLocaleString()} DZD/nuit
                    </span>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-2">${p.description || ''}</p>
                    <div class="mb-2">
                        ${p.includesBreakfast     ? '<span class="badge bg-light text-dark border me-1"><i class="bi bi-cup-hot"></i> Petit-dej</span>' : ''}
                        ${p.includesParking       ? '<span class="badge bg-light text-dark border me-1"><i class="bi bi-p-square"></i> Parking</span>' : ''}
                        ${p.includesSpa           ? '<span class="badge bg-light text-dark border me-1"><i class="bi bi-stars"></i> Spa</span>' : ''}
                        ${p.includesAirportTransfer ? '<span class="badge bg-light text-dark border me-1"><i class="bi bi-airplane"></i> Transfert</span>' : ''}
                        ${!p.includesBreakfast && !p.includesParking && !p.includesSpa && !p.includesAirportTransfer
                            ? '<span class="badge bg-secondary">Hebergement seul</span>' : ''}
                    </div>
                    ${p.minNights ? `<small class="text-muted"><i class="bi bi-moon"></i> Min. ${p.minNights} nuits</small>` : ''}
                </div>
                <div class="card-footer bg-white d-flex gap-2">
                    ${p.isActive
                        ? `<button class="btn btn-sm btn-outline-danger w-100"
                               onclick="deletePackage(${p.id})">
                               <i class="bi bi-trash"></i> Desactiver
                           </button>`
                        : `<span class="text-muted small w-100 text-center">Inactif</span>`
                    }
                </div>
            </div>
        </div>`).join('');
}

async function createPackage() {
    const dto = {
        name:                  document.getElementById('pkgName').value,
        description:           document.getElementById('pkgDesc').value,
        additionalPrice:       parseFloat(document.getElementById('pkgPrice').value) || 0,
        includesBreakfast:     document.getElementById('pkgBreakfast').checked,
        includesParking:       document.getElementById('pkgParking').checked,
        includesSpa:           document.getElementById('pkgSpa').checked,
        includesAirportTransfer: document.getElementById('pkgTransfer').checked,
        minNights:             parseInt(document.getElementById('pkgMinNights').value) || null
    };
    await fetch('/api/v1/packages', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(dto)
    });
    bootstrap.Modal.getInstance(document.getElementById('newPackageModal')).hide();
    loadPackages();
}

async function deletePackage(id) {
    if (!confirm('Desactiver ce package ?')) return;
    await fetch('/api/v1/packages/' + id, { method: 'DELETE' });
    loadPackages();
}

loadPackages();
</script>
}
