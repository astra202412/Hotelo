<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — HOTELO</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.0/font/bootstrap-icons.min.css" />
    <style>
        body { background: #f0f2f5; }
        .sidebar {
            width: 240px; min-height: 100vh; background: #1E3A5F;
            position: fixed; top: 0; left: 0; z-index: 100;
            transition: all 0.3s;
        }
        .sidebar .brand {
            padding: 20px 16px; border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .sidebar .brand span { color: #C9A84C; font-weight: 800; font-size: 1.4rem; letter-spacing: 2px; }
        .sidebar .brand small { color: rgba(255,255,255,0.5); font-size: 10px; display: block; }
        .sidebar .nav-link {
            color: rgba(255,255,255,0.7); padding: 10px 16px;
            border-radius: 6px; margin: 2px 8px;
            display: flex; align-items: center; gap: 10px;
            font-size: 14px; transition: all 0.2s;
        }
        .sidebar .nav-link:hover, .sidebar .nav-link.active {
            background: rgba(255,255,255,0.12); color: #fff;
        }
        .sidebar .nav-link i { width: 18px; text-align: center; font-size: 16px; }
        .sidebar .nav-section {
            color: rgba(255,255,255,0.3); font-size: 10px; font-weight: 700;
            letter-spacing: 1px; padding: 12px 24px 4px; text-transform: uppercase;
        }
        .main-content { margin-left: 240px; min-height: 100vh; }
        .topbar {
            background: #fff; border-bottom: 1px solid #e5e7eb;
            padding: 12px 24px; display: flex;
            justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 99;
        }
        .page-content { padding: 24px; }
        .card { border: none; border-radius: 10px; }
        .badge-status { font-size: 11px; padding: 4px 8px; border-radius: 20px; }
    </style>
</head>
<body>

<!-- Sidebar -->
<div class="sidebar">
    <div class="brand">
        <span>HOTELO</span>
        <small>Hotel Management System</small>
    </div>
    <nav class="mt-3">
        <div class="nav-section">Principal</div>
        <a asp-controller="Dashboard" asp-action="Index" asp-area=""
           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
            <i class="bi bi-grid-fill"></i> Dashboard
        </a>

        <div class="nav-section">Operations</div>
        <a asp-area="FrontOffice" asp-controller="Home" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "FrontOffice" ? "active" : "")">
            <i class="bi bi-building"></i> Front Office
        </a>
        <a asp-area="Reservation" asp-controller="Packages" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Packages" ? "active" : "")">
            <i class="bi bi-gift"></i> Packages
        </a>
        <a asp-area="Reservation" asp-controller="Home" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "Reservation" ? "active" : "")">
            <i class="bi bi-calendar-check"></i> Reservations
        </a>
        <a asp-area="Finances" asp-controller="Home" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "Finances" ? "active" : "")">
            <i class="bi bi-receipt"></i> Finances
        </a>

        <div class="nav-section">Services</div>
        <a asp-area="Housekeeping" asp-controller="Home" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "Housekeeping" ? "active" : "")">
            <i class="bi bi-stars"></i> Housekeeping
        </a>
        <a asp-area="HR" asp-controller="Home" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "HR" ? "active" : "")">
            <i class="bi bi-people-fill"></i> Ressources Humaines
        </a>
        <a asp-area="Commercial" asp-controller="Home" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "Commercial" ? "active" : "")">
            <i class="bi bi-graph-up-arrow"></i> Commercial
        </a>
        <a asp-area="Technique" asp-controller="Home" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "Technique" ? "active" : "")">
            <i class="bi bi-tools"></i> Technique
        </a>
        <a asp-area="BellDesk" asp-controller="Home" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "BellDesk" ? "active" : "")">
            <i class="bi bi-bell-fill"></i> Bell Desk
        </a>

        <a asp-controller="Reports" asp-action="Index" asp-area=""
           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")">
            <i class="bi bi-graph-up-arrow"></i> Rapports Direction
        </a>
        <div class="nav-section">Systeme</div>
        <a asp-area="Admin" asp-controller="Departments" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Departments" ? "active" : "")">
            <i class="bi bi-diagram-3"></i> Departements & Fonctions
        </a>
        <a asp-area="Admin" asp-controller="UserAccess" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "UserAccess" ? "active" : "")">
            <i class="bi bi-person-check"></i> Gestion des Acces
        </a>
        <a asp-area="Admin" asp-controller="Backup" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Backup" ? "active" : "")">
            <i class="bi bi-database-fill-gear"></i> Backup & Restauration
        </a>

        <a asp-area="Admin" asp-controller="Home" asp-action="Index"
           class="nav-link @(ViewContext.RouteData.Values["area"]?.ToString() == "Admin" ? "active" : "")">
            <i class="bi bi-shield-lock-fill"></i> Administration
        </a>
        <a href="/swagger" target="_blank" class="nav-link">
            <i class="bi bi-code-slash"></i> API Swagger
        </a>
    </nav>
</div>

<!-- Main Content -->
<div class="main-content">
    <!-- Topbar -->
    <div class="topbar">
        <div class="fw-semibold text-dark">@ViewData["Title"]</div>
        <div class="d-flex align-items-center gap-3">
            <span class="badge bg-success">En ligne</span>
            <span class="text-muted small">@User.Identity?.Name</span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                <button type="submit" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-box-arrow-right"></i> Deconnexion
                </button>
            </form>
        </div>
    </div>

    <!-- Page Content -->
    <div class="page-content">
        @RenderBody()
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

<!-- Toast notifications -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
    <div id="toastContainer"></div>
</div>

<script>
const connection = new signalR.HubConnectionBuilder()
    .withUrl("/hubs/notifications")
    .withAutomaticReconnect()
    .build();

connection.on("ReceiveNotification", function(msg) {
    showToast(msg.title, msg.message, msg.type);
});

connection.on("RoomStatusUpdated", function(data) {
    showToast("Statut Chambre", data.roomNumber + " -> " + data.status, "Info");
    // Recharger le plan si on est sur FrontOffice
    if (window.location.pathname.includes("FrontOffice") && typeof loadRooms === "function") {
        loadRooms();
    }
});

connection.start().catch(err => console.log("SignalR:", err));

function showToast(title, message, type) {
    const colors = { Success:"#4CAF50", Info:"#2196F3", Warning:"#FF9800", Error:"#F44336" };
    const id = "toast_" + Date.now();
    const html = `
        <div id="${id}" class="toast show align-items-center text-white border-0 mb-2"
             style="background:${colors[type] || "#333"};min-width:280px;"
             role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    <strong>${title}</strong><br>
                    <small>${message}</small>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                    onclick="document.getElementById('${id}').remove()"></button>
            </div>
        </div>`;
    document.getElementById("toastContainer").insertAdjacentHTML("beforeend", html);
    setTimeout(() => { const t = document.getElementById(id); if(t) t.remove(); }, 5000);
}
</script>
